#!/bin/sh

set -eu

APP_HOME=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
WRAPPER_JAR="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

if [ -f "$WRAPPER_JAR" ]; then
  if [ -n "${JAVA_HOME:-}" ]; then
    JAVA_CMD="$JAVA_HOME/bin/java"
  else
    JAVA_CMD="java"
  fi
  exec "$JAVA_CMD" -classpath "$WRAPPER_JAR" org.gradle.wrapper.GradleWrapperMain "$@"
fi

if command -v gradle >/dev/null 2>&1; then
  exec gradle "$@"
fi

cat >&2 <<'EOF'
DIREKT requires Gradle 9.4.0 for the first bootstrap.

Install Gradle 9.4.0 or run the GitHub Actions workflow. The workflow creates the
standard wrapper JAR from the pinned distribution before executing this launcher.
EOF
exit 1
