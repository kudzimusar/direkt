{
  "name": "@direkt/customer-provider-web",
  "version": "0.1.0",
  "private": true,
  "description": "Functional DIREKT customer/provider responsive web and PWA client",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "verify:static": "node scripts/verify-static-contract.mjs",
    "verify:discovery": "node scripts/verify-discovery-contract.mjs",
    "verify:auth": "node scripts/verify-auth-contract.mjs",
    "verify": "npm run typecheck && npm run verify:static && npm run verify:discovery && npm run verify:auth && npm run build"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "typescript": "5.9.3"
  }
}
