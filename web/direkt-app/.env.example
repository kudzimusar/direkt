# Functional DIREKT web/PWA runtime mode.
# Keep disabled for W1 shell-only development.
DIREKT_WEB_API_MODE=disabled

# Server-only canonical DIREKT API base URL.
# Never prefix this value with NEXT_PUBLIC_.
# Required only when DIREKT_WEB_API_MODE=public or authenticated-bff.
DIREKT_API_BASE_URL=

# Future authenticated browser/BFF values are added only through a reviewed workstream.
# Do not place Firebase private keys, Supabase service-role keys, database credentials,
# participant data or long-lived bearer tokens in this file.
