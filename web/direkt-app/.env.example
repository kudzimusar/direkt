# Functional DIREKT web/PWA runtime mode.
# Keep disabled for shell-only development.
# `public` is local/non-production only. Production discovery must use `authenticated-bff`
# so the Next.js server can invoke the IAM-private DIREKT API without exposing it to browsers.
DIREKT_WEB_API_MODE=disabled

# Server-only canonical DIREKT API base URL.
# Never prefix this value with NEXT_PUBLIC_.
# Required only when DIREKT_WEB_API_MODE=public or authenticated-bff.
DIREKT_API_BASE_URL=

# W3 browser authentication mode.
# - disabled: no participant sign-in routes are active.
# - synthetic: managed synthetic staging only; additionally requires
#   DIREKT_WEB_ALLOW_SYNTHETIC_AUTH=true and authenticated-bff API mode.
# - firebase-exchange: accepts a Firebase phone ID token through the reviewed BFF exchange;
#   real browser Firebase configuration remains separately gated.
DIREKT_WEB_AUTH_MODE=disabled
DIREKT_WEB_ALLOW_SYNTHETIC_AUTH=false

# Server-controlled pilot notice version used for Firebase-to-DIREKT exchange.
# Required only when DIREKT_WEB_AUTH_MODE=firebase-exchange.
DIREKT_WEB_PILOT_NOTICE_VERSION=

# Optional exact public origin for mutation-origin enforcement.
# When omitted, the BFF derives the incoming request origin from trusted request headers.
DIREKT_WEB_ORIGIN=

# Never place Firebase private keys, Supabase service-role keys, database credentials,
# participant data, DIREKT access/refresh tokens, or other long-lived bearer credentials here.
