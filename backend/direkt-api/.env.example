NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgresql://direkt:direkt_dev@localhost:5432/direkt
# DIRECT_DATABASE_URL is used only by protected migrations and administrative checks.
CORS_ORIGINS=
TRUST_PROXY_HOPS=0
DIREKT_ENVIRONMENT=local
DIREKT_DATA_MODE=synthetic-only
DIREKT_TRAFFIC_MODE=internal
# Technical latch only. It never substitutes for the recorded Phase 11 legal/privacy/provider/operations approvals.
PILOT_ENTRY_APPROVED=false
RATE_LIMITS_ENABLED=true
RATE_LIMIT_HASH_PEPPER=direkt-development-rate-limit-hash-pepper-not-for-production-000001
AUTH_CHALLENGE_MODE=synthetic
ACCESS_TOKEN_SECRET=direkt-development-access-token-secret-not-for-production-000000000001
CONTACT_HASH_PEPPER=direkt-development-contact-hash-pepper-not-for-production-000000001
CHALLENGE_HASH_PEPPER=direkt-development-challenge-hash-pepper-not-for-production-0000001
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_TOKEN_TTL_DAYS=30
CHALLENGE_TTL_SECONDS=300

# Use "supabase" only after the remote project is linked, migrated and verified.
EVIDENCE_STORAGE_PROVIDER=synthetic
# SUPABASE_URL=https://aeeuscifrxcjmnswqwnq.supabase.co
# SUPABASE_SECRET_KEY is supplied locally or through the protected runtime secret store.
SUPABASE_EVIDENCE_BUCKET=provider-evidence
SUPABASE_PRIVATE_MEDIA_BUCKET=provider-media-private
SUPABASE_PUBLIC_MEDIA_BUCKET=provider-media-public
SUPABASE_SYSTEM_EXPORTS_BUCKET=system-exports

# Synthetic is allowed only in development/test. Production accepts "disabled" only.
PAYMENT_PROVIDER_MODE=synthetic
PAYMENT_SYNTHETIC_WEBHOOK_SECRET=direkt-development-synthetic-payment-webhook-secret-not-for-production-0001
