{
  "name": "@direkt/api",
  "version": "0.1.0",
  "private": true,
  "description": "DIREKT modular backend foundation",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node --transpile-only src/main.ts",
    "format": "prettier --write \"{src,scripts,test}/**/*.ts\" \"*.{json,js,mjs}\"",
    "format:check": "prettier --check \"{src,scripts,test}/**/*.ts\" \"*.{json,js,mjs}\"",
    "lint": "eslint src scripts test --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "migration:up": "ts-node --project tsconfig.json scripts/migrate.ts",
    "migration:check": "ts-node --project tsconfig.json scripts/check-migrations.ts",
    "seed:synthetic": "ts-node --project tsconfig.json scripts/seed-synthetic.ts",
    "openapi:generate": "ts-node --project tsconfig.json scripts/generate-openapi.ts",
    "openapi:check": "ts-node --project tsconfig.json scripts/check-openapi.ts",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "joi": "18.2.3",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@nestjs/testing": "11.1.28",
    "@types/express": "5.0.6",
    "@types/node": "24.13.3",
    "@types/pg": "8.15.6",
    "@types/supertest": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.4",
    "prettier": "3.9.5",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.10"
  }
}
